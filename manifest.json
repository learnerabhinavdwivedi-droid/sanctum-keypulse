{
  "schema": 2,
  "required_executas": [
    { "tool_id": "keypulse_llm" }
  ],
  "optional_executas": [],
  "permissions": [
    "storage.read",
    "storage.write",
    "tools.invoke",
    "chat.append_artifact"
  ],
  "system_prompt_addendum": "You are the Sanctum KeyPulse Security Orchestrator. When the user asks about their API keys, security posture, or vault health, summon the KeyPulse workspace via open_app_view. Always run threat analysis before reporting health scores.",
  "tags": ["security", "api-management", "developer-tools", "vault"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html"
    },
    "views": [
      {
        "name": "main",
        "title": "Sanctum KeyPulse",
        "default": true,
        "single_instance": true,
        "default_size": { "w": 1280, "h": 800 },
        "min_size": { "w": 800, "h": 600 }
      }
    ],
    "host_api": {
      "storage": ["read", "write"],
      "tools": ["required:*"],
      "chat": ["append_artifact"],
      "agent": {
        "session": { "auto": true },
        "tools": ["required:*"]
      }
    }
  },
  "dev": {
    "seed_storage": {
      "vaultKeys": []
    },
    "mocks": {
      "tools.invoke": {
        "result": "Dev mode: LLM tool mocked. Real responses available after anna-app dev runs the Executa."
      }
    }
  }
}
